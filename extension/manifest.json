{
  "manifest_version": 3,
  "name": "Tab Suspender - Save Memory",
  "version": "1.0.0",
  "description": "Automatically suspend inactive tabs to free up RAM. Configurable timeouts, domain whitelist, and smart tab protection.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "settings/settings.html",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "commands": {
    "suspend-current-tab": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Suspend the current tab"
    }
  }
}
